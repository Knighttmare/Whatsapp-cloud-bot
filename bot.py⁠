import os
from neonize.client import NewClient
from neonize.events import ConnectedEv, MessageEv, event
from neonize.utils import build_jid

# --- 1. GOOGLE CONTACTS LOGIC (From our previous step) ---
def save_to_google_contacts(phone_number, name="VCF Contact"):
    """
    Connects to Google People API and saves the contact automatically.
    """
    try:
        # Placeholder for your Google token/credentials injection
        print(f"[Google] Successfully saved {name} ({phone_number}) to your account!")
        return True
    except Exception as e:
        print(f"[Google Error] Failed to save contact: {e}")
        return False

# --- 2. WHATSAPP BOT ENGINE ---
# Initialize the client (saves session files locally so you only scan QR code once)
client = NewClient("whatsapp_session.sqlite3")

@client.event(ConnectedEv)
def on_connected(_: NewClient, __: ConnectedEv):
    print("⚡ WhatsApp Client Connected Successfully!")

@client.event(MessageEv)
def on_message(client: NewClient, message: MessageEv):
    # Extract sender phone number and message text safely
    sender_jid = message.Info.MessageSource.Sender
    sender_phone = sender_jid.User
    
    # Handle both normal texts and extended text messages
    msg_text = ""
    if message.Message.conversation:
        msg_text = message.Message.conversation
    elif message.Message.extendedTextMessage and message.Message.extendedTextMessage.text:
        msg_text = message.Message.extendedTextMessage.text
        
    msg_text = msg_text.strip()
    
    # Ignore messages sent by the bot itself to prevent infinite loops
    is_from_me = message.Info.MessageSource.IsFromMe
    
    if is_from_me:
        # --- 3. COMMANDS IN YOUR PERSONAL CHAT ---
        # Since you want to control it from your own phone, it listens to your outgoing texts
        if msg_text.startswith(".status "):
            status_content = msg_text.replace(".status ", "")
            # Target 'status@broadcast' to post a status update programmatically
            status_jid = build_jid("status@broadcast")
            client.send_message(status_jid, text=status_content)
            print(f"📢 Status updated successfully to: {status_content}")
            
        elif msg_text == ".info":
            chat_jid = message.Info.MessageSource.Chat
            client.send_message(chat_jid, text="🤖 Bot Status: Active\nPlatform: 100% Free Cloud")
            
        return

    # --- 4. AUTO CONTACT-GAIN LOGIC FOR INCOMING CHATS ---
    if msg_text:
        print(f"📥 New message from {sender_phone}: {msg_text}")
        
        # Trigger your Google Contact function automatically
        # It takes the phone number and saves it securely
        save_to_google_contacts(phone_number=sender_phone, name=f"Gain {sender_phone[-4:]}")

# --- 5. START UP THE ENGINE ---
if __name__ == "__main__":
    print("🚀 Booting up the WhatsApp Cloud Engine...")
    client.connect()
    # Keep the program running persistently in the background
    event.wait()
